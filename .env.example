# ============== Required ==============
# === Zotero ===
Z_SCOPE=user
Z_ID=YOUR_ZOTERO_USER_OR_GROUP_ID
Z_API_KEY=your_zotero_api_key_here

# === Translator ===
TRANSLATOR_PROVIDER=deepl
# TRANSLATOR_PROVIDER=chatgpt
# TRANSLATOR_PROVIDER=local_llm
TARGET_LANG=JA

# Required if TRANSLATOR_PROVIDER=deepl
DEEPL_API_KEY=your_deepl_api_key_here

# Required if TRANSLATOR_PROVIDER=chatgpt
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Required if TRANSLATOR_PROVIDER=local_llm
# Standard local example: Ollama + qwen2.5:7b-instruct
# Point this to Ollama's OpenAI-compatible /v1 endpoint.
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=qwen2.5:7b-instruct


# ============== Optional (Defaults Applied) ==============

# === Translator ===
# DeepL API endpoint. Use https://api.deepl.com for Pro.
DEEPL_API_URL=https://api-free.deepl.com
# ChatGPT API endpoint. Keep the default for the official OpenAI API.
OPENAI_BASE_URL=https://api.openai.com/v1
# Optional source language. Leave unset to use provider auto-detection.
# SOURCE_LANG=EN

# === Pipeline ===
Z_TARGET_TAG=to-translate
Z_DONE_TAG=translated
Z_REMOVE_TAG=to-translate
Z_BASE_DONE_TAG=base-done
# Tag added before translation.
ANN_PENDING_TRANSLATION_TAG=za:translate
# Tag added after translation.
ANN_TRANSLATED_TAG=za:translated

# Paragraph length filter.
PARA_MIN_CHARS=60
PARA_MAX_CHARS=1500
# Minimum median font size to keep a paragraph. Use auto or 0 to disable.
PARA_MIN_MEDIAN_COORD_H=auto
# Auto threshold multiplier when PARA_MIN_MEDIAN_COORD_H=auto.
PARA_MIN_MEDIAN_COORD_H_AUTO_RATIO=0.8
# Skip algorithm / pseudocode blocks.
PARA_SKIP_ALGORITHMS=1
# Skip standalone figure / table captions.
PARA_SKIP_CAPTIONS=0
# Remove inline citation markers like [23].
PARA_DROP_CITATIONS=0
# Remove footnote markers like layer1. -> layer.
PARA_DROP_FOOTNOTE_MARKERS=0
# Skip references / bibliography section.
PARA_SKIP_REFERENCES=1
# Skip table-body-like paragraphs.
PARA_SKIP_TABLE_LIKE=1
