# ============== Required ==============
# === Zotero ===
Z_SCOPE=user
Z_ID=YOUR_ZOTERO_USER_OR_GROUP_ID
Z_API_KEY=your_zotero_api_key_here

# === Gemini ===
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
TARGET_LANG=JA

# === GROBID ===
GROBID_URL=http://localhost:8070


# ============== Optional (Defaults Applied) ==============
# === Gemini ===
GEMINI_CONCURRENCY=2
GEMINI_TIMEOUT_SECONDS=30
GEMINI_MAX_RETRIES=3
GEMINI_QUOTA_STOP=true
GEMINI_QUOTA_EXIT_CODE=10

# === GROBID ===
GROBID_TIMEOUT_SECONDS=60

# === Pipeline ===
Z_TARGET_TAG=to-translate
Z_DONE_TAG=translated
Z_REMOVE_TAG=to-translate
Z_IN_PROGRESS_TAG=translating
PARA_MIN_CHARS=60
PARA_MAX_CHARS=1500
LOG_LEVEL=INFO
