# ============== Required ==============
# === Zotero ===
Z_SCOPE=user
Z_ID=YOUR_ZOTERO_USER_OR_GROUP_ID
Z_API_KEY=your_zotero_api_key_here

# === Translator ===
TRANSLATOR_PROVIDER=deepl
# TRANSLATOR_PROVIDER=openai
TARGET_LANG=JA

# Required if TRANSLATOR_PROVIDER=deepl
DEEPL_API_KEY=your_deepl_api_key_here

# Required if TRANSLATOR_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here

# ============== Optional (Defaults Applied) ==============

# === Translator ===
# DeepL free endpoint: https://api-free.deepl.com
# DeepL pro endpoint:  https://api.deepl.com
DEEPL_API_URL=https://api-free.deepl.com
# SOURCE_LANG is optional. If omitted, some providers auto-detect.
SOURCE_LANG=JA

# === Pipeline ===
Z_TARGET_TAG=to-translate
Z_DONE_TAG=translated
Z_REMOVE_TAG=to-translate
Z_BASE_DONE_TAG=base-done
# Annotation(note) tag added before translation for targeted annotations.
ANN_PENDING_TRANSLATION_TAG=za:translate
# Annotation(note) tag added after translation completes.
ANN_TRANSLATED_TAG=za:translated

PARA_MIN_CHARS=10
PARA_MAX_CHARS=10000
PARA_MIN_MEDIAN_COORD_H=auto
PARA_MIN_MEDIAN_COORD_H_AUTO_RATIO=0.8
PARA_SKIP_ALGORITHMS=1
PARA_SKIP_CAPTIONS=0
